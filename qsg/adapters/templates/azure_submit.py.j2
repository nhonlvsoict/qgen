import os, json
from azure.quantum import Workspace


def props_to_dict(details):
    """Safely extract timing fields from Azure job details."""
    out = {}
    key_map = {
        "compiling_s": ["compilation_time", "compile_time", "transpile_time"],
        "queue_s": ["queue_time"],
        "running_s": ["run_time", "execution_time"],
        "total_s": ["total_time", "wall_time", "elapsed_time"],
    }

    detail_dict = details if isinstance(details, dict) else getattr(details, "__dict__", {})
    for key, names in key_map.items():
        for name in names:
            value = detail_dict.get(name)
            if value is not None:
                try:
                    out[key] = float(value)
                except Exception:
                    out[key] = value
                break
    return out or None


connection_string = os.getenv("CONNECTION_STRING")

if not all([connection_string]):
    raise RuntimeError(
        "Missing Azure Quantum workspace configuration environment variables",
    )

workspace = Workspace.from_connection_string(str(connection_string))

with open("{{ payload_path }}", "rb") as f:
    program = f.read()

target = workspace.get_targets(name="{{ target }}") 
job = target.submit(
    input_data=program,
    input_data_format="qir.v1",
    output_data_format="microsoft.quantum-results.v1",
    name="my-qir-job",
    input_params={"entryPoint": "main", "arguments": [], "shots": 8192},
)
print("Submitted job1:", job.id)

job.wait_until_completed()
result = job.get_results()
properties = props_to_dict(job.details)
payload = {"counts": result}
if properties:
    payload["properties"] = properties
print(json.dumps(payload))

