import os, json, time
from datetime import datetime, timezone
from azure.quantum import Workspace

def _to_dt(x):
    if not x:
        return None
    try:
        return datetime.fromisoformat(str(x).replace("Z", "+00:00")).astimezone(timezone.utc)
    except Exception:
        return None

def extract_spans(job):
    """
    Return {"compiling_s","queue_s","running_s","total_s"} when possible.
    1) Try provider job.properties() (provider-specific keys).
    2) Else derive from timestamps on job.details (creation/begin/end).
    """
    out = {}

    # (1) provider-specific
    try:
        props = job.properties()
    except Exception:
        props = None
    if isinstance(props, dict):
        key_map = {
            "compiling_s": ["compilation_time", "compile_time", "transpile_time"],
            "queue_s":     ["queue_time"],
            "running_s":   ["run_time", "execution_time"],
            "total_s":     ["total_time", "wall_time", "elapsed_time"],
        }
        for dst, keys in key_map.items():
            for k in keys:
                v = props.get(k)
                if v is not None:
                    try:
                        out[dst] = float(v)
                    except Exception:
                        pass
                    break

    # (2) derive from timestamps (after a fresh fetch)
    d = getattr(job, "details", None)
    if d:
        created = _to_dt(getattr(d, "creation_time", None) or getattr(d, "creationTime", None))
        begin   = _to_dt(getattr(d, "begin_execution_time", None) or getattr(d, "beginExecutionTime", None))
        end     = _to_dt(getattr(d, "end_execution_time", None) or getattr(d, "endExecutionTime", None))
        if created and begin and "queue_s"   not in out: out["queue_s"]   = (begin - created).total_seconds()
        if begin   and end   and "running_s" not in out: out["running_s"] = (end   - begin  ).total_seconds()
        if created and end   and "total_s"   not in out: out["total_s"]   = (end   - created).total_seconds()

    return out or None

connection_string = os.getenv("CONNECTION_STRING")

if not all([connection_string]):
    raise RuntimeError(
        "Missing Azure Quantum workspace configuration environment variables",
    )

workspace = Workspace.from_connection_string(str(connection_string))

with open("{{ payload_path }}", "rb") as f:
    program = f.read()

target = workspace.get_targets(name="{{ target }}") 

# measure wall clock too (in case provider fields are missing)
t0 = time.perf_counter()

job = target.submit(
    input_data=program,
    input_data_format="qir.v1",
    output_data_format="microsoft.quantum-results.v1",
    name="my-new-qir-job",
    input_params={"entryPoint": "main", "arguments": [], "shots": 8192},
)
print("Submitted job1:", job.id)

job.wait_until_completed()

# Re-fetch to ensure details include final timestamps on some targets
job = workspace.get_job(job.id)

result = job.get_results()       # normalized histogram (probabilities)
spans  = extract_spans(job)

payload = {"counts": result}
if spans:
    payload["properties"] = spans
else:
    # fallback: include wall clock total if nothing else
    payload["properties"] = {"total_wall_clock_s": round(time.perf_counter() - t0, 6)}

print(json.dumps(payload))