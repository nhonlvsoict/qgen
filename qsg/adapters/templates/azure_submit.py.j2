import os, json
from datetime import datetime, timezone
from azure.quantum import Workspace

def _to_dt(x):
    if not x:
        return None
    # Azure usually returns RFC3339/ISO8601; be permissive
    try:
        # 2024-07-26T12:34:56.789Z
        return datetime.fromisoformat(x.replace("Z", "+00:00")).astimezone(timezone.utc)
    except Exception:
        return None

def extract_spans(job):
    """
    Returns a small dict like:
      {"compiling_s": ..., "queue_s": ..., "running_s": ..., "total_s": ...}
    using (1) job.properties() if available; else
    (2) timestamps on job.details to compute queue/run/total.
    Missing values are omitted.
    """
    out = {}

    # (1) Try provider-specific properties first (may be empty/None)
    try:
        props = job.properties()
    except Exception:
        props = None

    if isinstance(props, dict):
        # Map any friendly keys if present
        for dest, keys in {
            "compiling_s": ["compilation_time", "compile_time", "transpile_time"],
            "queue_s":     ["queue_time"],
            "running_s":   ["run_time", "execution_time"],
            "total_s":     ["total_time", "wall_time", "elapsed_time"],
        }.items():
            for k in keys:
                v = props.get(k)
                if v is not None:
                    try:
                        out[dest] = float(v)
                    except Exception:
                        pass
                    break

    # (2) Derive from timestamps if any span is still missing
    d = getattr(job, "details", None)
    if d:
        # Common timestamp names (different providers use different casings)
        created = _to_dt(getattr(d, "creation_time", None) or getattr(d, "creationTime", None))
        begin   = _to_dt(getattr(d, "begin_execution_time", None) or getattr(d, "beginExecutionTime", None))
        end     = _to_dt(getattr(d, "end_execution_time", None) or getattr(d, "endExecutionTime", None))

        if created and begin and "queue_s" not in out:
            out["queue_s"] = (begin - created).total_seconds()
        if begin and end and "running_s" not in out:
            out["running_s"] = (end - begin).total_seconds()
        if created and end and "total_s" not in out:
            out["total_s"] = (end - created).total_seconds()

    return out or None

connection_string = os.getenv("CONNECTION_STRING")

if not all([connection_string]):
    raise RuntimeError(
        "Missing Azure Quantum workspace configuration environment variables",
    )

workspace = Workspace.from_connection_string(str(connection_string))

with open("{{ payload_path }}", "rb") as f:
    program = f.read()

target = workspace.get_targets(name="{{ target }}") 
job = target.submit(
    input_data=program,
    input_data_format="qir.v1",
    output_data_format="microsoft.quantum-results.v1",
    name="my-qir-job",
    input_params={"entryPoint": "main", "arguments": [], "count": 8192},
)
print("Submitted job1:", job.id)

job.wait_until_completed()

result = job.get_results()

payload = {"counts": result}
spans = extract_spans(job)
if spans:
    payload["properties"] = spans

print(json.dumps(payload))

