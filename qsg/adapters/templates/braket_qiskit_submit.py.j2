import json, os, time
from importlib.util import spec_from_file_location, module_from_spec
from datetime import datetime, timezone

import boto3
from braket.aws import AwsQuantumTask
from qiskit_braket_provider import BraketProvider
from qiskit import transpile

# ---------- helpers ----------
def _to_dt(x):
    if not x:
        return None
    try:
        return datetime.fromisoformat(str(x).replace("Z", "+00:00")).astimezone(timezone.utc)
    except Exception:
        return None

def load_circuit(path: str):
    spec = spec_from_file_location("payload", path)
    module = module_from_spec(spec)
    spec.loader.exec_module(module)
    if not hasattr(module, "build_circuit"):
        raise ValueError("Expected a build_circuit() function in the payload")
    return module.build_circuit()

def monitor_until_running_and_done(task: AwsQuantumTask, poll_s: float = 2.0):
    created_at = _to_dt(task.metadata().get("createdAt"))
    began_at = None
    ended_at = None

    while True:
        state = task.state()
        now = datetime.now(timezone.utc)
        if state == "RUNNING" and began_at is None:
            began_at = now
        if state in ("COMPLETED", "FAILED", "CANCELLING", "CANCELLED"):
            meta = task.metadata()
            ended_at = _to_dt(meta.get("endedAt")) or now
            return created_at, began_at, ended_at
        time.sleep(poll_s)

def spans_from_timestamps(created_at, began_at, ended_at, wall_clock_start):
    out = {}
    if created_at and began_at:
        out["queue_s"] = (began_at - created_at).total_seconds()
    if began_at and ended_at:
        out["running_s"] = (ended_at - began_at).total_seconds()
    if created_at and ended_at:
        out["total_s"] = (ended_at - created_at).total_seconds()
    out["total_wall_clock_s"] = round(time.perf_counter() - wall_clock_start, 6)
    return out

# ---------- main ----------
payload_path = "{{ payload_path }}"
shots = 100

qc = load_circuit(payload_path)
# qc = transpile(qc, optimization_level=3)

# Provider with no args (region comes from AWS_DEFAULT_REGION or ~/.aws/config)
provider = BraketProvider()

backend = provider.get_backend("Garnet")  # Rigetti backend by name

t0 = time.perf_counter()
job = backend.run(qc, shots=shots)
print("Job ID:", job.job_id())

# Underlying Braket task ARN is the job_id
task = AwsQuantumTask(job.job_id())
created_at, began_at, ended_at = monitor_until_running_and_done(task)

result = job.result()
counts = result.get_counts()
spans = spans_from_timestamps(created_at, began_at, ended_at, t0)

print(json.dumps({"counts": counts, "properties": spans}))
