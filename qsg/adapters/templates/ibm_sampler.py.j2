import os, json, time
from datetime import datetime

from qiskit.transpiler.preset_passmanagers import generate_preset_pass_manager
from qiskit.qasm3 import loads

def props_to_dict(props, job_result=None):
    """
    Safely extract only timing fields (compiling, queue, running, total)
    from job.properties(), and fall back to execution spans in job_result
    to compute running_s when needed. Returns a small JSON-serialisable dict.
    """
    out = {}
    key_map = {
        "compiling_s": ["compilation_time", "compile_time", "transpile_time"],
        "queue_s":     ["queue_time"],
        "running_s":   ["run_time", "execution_time"],
        "total_s":     ["total_time", "wall_time", "elapsed_time"],
    }

    try:
        # Add execution spans if available
        if job_result is not None and hasattr(job_result, "metadata"):
            exec_meta = job_result.metadata.get("execution", {})
            spans = exec_meta.get("execution_spans")
            if spans:
                out["spans"] = []
                total_run = 0.0
                for sp in spans:
                    # support both object-like and dict-like spans
                    start_raw = getattr(sp, "start", None) if not isinstance(sp, dict) else sp.get("start")
                    stop_raw  = getattr(sp, "stop", None)  if not isinstance(sp, dict) else sp.get("stop")
                    size_raw  = getattr(sp, "size", None)  if not isinstance(sp, dict) else sp.get("size")
                    span_dict = {"start": str(start_raw), "stop": str(stop_raw), "size": size_raw}
                    # compute duration if possible
                    try:
                        t0 = datetime.fromisoformat(str(start_raw))
                        t1 = datetime.fromisoformat(str(stop_raw))
                        span_dict["duration_s"] = round((t1 - t0).total_seconds(), 6)
                        total_run += span_dict["duration_s"]
                    except Exception:
                        pass
                    out["spans"].append(span_dict)

                # If no running_s from props, use span sum
                if "running_s" not in out and total_run > 0:
                    out["running_s"] = round(total_run, 6)


    except Exception as e:
        out["error"] = f"Could not extract timings: {e}"

    return out or None

def get_times_from_props(props, job_result=None):
    """
    Extracts timing fields from job properties.
    Returns a dict with keys: compiling_s, queue_s, running_s, total_s.
    If job_result is provided, it will also extract execution spans.
    """
    try:
        if job_result is not None and hasattr(job_result, "metadata"):
            exec_meta = job_result.metadata.get("execution", {})
            spans = exec_meta.get("execution_spans")
            total_run = 0.0
            if spans:
                for sp in spans:
                    # support both object-like and dict-like spans
                    start_raw = getattr(sp, "start", None) if not isinstance(sp, dict) else sp.get("start")
                    stop_raw  = getattr(sp, "stop", None)  if not isinstance(sp, dict) else sp.get("stop")
                    size_raw  = getattr(sp, "size", None)  if not isinstance(sp, dict) else sp.get("size")
                    span_dict = {"start": str(start_raw), "stop": str(stop_raw), "size": size_raw}
                    # compute duration if possible
                    try:
                        t0 = datetime.fromisoformat(str(start_raw))
                        t1 = datetime.fromisoformat(str(stop_raw))
                        total_run = round((t1 - t0).total_seconds(), 6)
                        
                    except Exception:
                        pass
            return total_run
    except Exception:
        pass
    return None

def extract_counts_v2(primitive_result):
    """Get counts dict from Primitives v2 Sampler result."""
    try:
        pub = primitive_result[0]  # SamplerPubResult
        return pub.join_data().get_counts()
    except Exception:
        try:
            return pub.data.c.get_counts()  # common reg name
        except Exception:
            return None
start = time.time()
qasm3 = open("{{ payload_path }}").read()
qc = loads(qasm3)

token = os.getenv("{{ token_env_var }}")
result_payload = {"backend_mode": None, "counts": None, "elapsed_s": None}

if not token:
    # Local simulation
    # If the token is not set, we will run a local simulation using Qiskit
    # This is useful for testing or when the IBM Quantum Experience is not available
    print("No {{ token_env_var }} env var found; running local simulation via qiskit instead.")
    try:
        from qiskit_aer.primitives import Sampler as LocalSampler
    except ImportError:
        from qiskit_ibm_runtime import Sampler as LocalSampler
    sampler = LocalSampler()
    res = sampler.run(qc).result()
    result_payload["backend_mode"] = "aer_local"
    # For primitives v0, use quasi_dists; newer APIs may have .quasi_dists or ._pub_results
    qd = getattr(res, "quasi_dists", None)
    if qd: result_payload["counts"] = qd[0]
else:
    #ibm_quantum_platform
    from qiskit_ibm_runtime import QiskitRuntimeService, SamplerV2 as Sampler
    service = QiskitRuntimeService(channel="ibm_quantum_platform", token=token, instance="quantum")
    backend = service.least_busy(operational=True, simulator=False)
    sampler = Sampler(mode=backend)
    sampler.options.default_shots = 8192  # Options can be set using auto-complete.

    pm = generate_preset_pass_manager(backend=backend, optimization_level=1)
    isa_circuit = pm.run(qc)
    job = sampler.run([isa_circuit])
    
    # Get job properties
    props = job.properties()

    res = job.result()
    result_payload["backend_mode"] = "ibmq_qasm"
    result_payload["properties"] = props_to_dict(props, res)
    result_payload["counts"] = extract_counts_v2(res)



result_payload["elapsed_s"] = round(time.time() - start, 4)
print(json.dumps(result_payload))